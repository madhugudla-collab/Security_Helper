# ============================================================
# Security Orchestrator Bot - Environment Variables
# Copy this to .env and fill in real values
# ============================================================

# Required: OpenAI API Key (GPT-4 for AI analysis)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Required: GitHub Token (for creating branches and PRs)
# Create at: https://github.com/settings/tokens/new
# Select: Classic token → check "repo" scope
GITHUB_TOKEN=ghp_your-github-classic-token-here

# ============================================================
# Optional: SonarQube Integration
# ============================================================

# SonarQube server URL
# - Local: http://localhost:9000
# - SonarCloud: https://sonarcloud.io
SONARQUBE_URL=http://localhost:9000

# SonarQube token (get from SonarQube → My Account → Security → Generate Tokens)
# If expired: go to SonarQube UI → My Account → Security → Generate new token
SONARQUBE_TOKEN=squ_your-sonarqube-token-here

# SonarCloud Organization (only needed for sonarcloud.io)
# SONARCLOUD_ORG=your-github-org-name

# ============================================================
# Optional: Corgea Integration (AI-powered auto-remediation)
# ============================================================
CORGEA_API_KEY=your-corgea-api-key-here

# ============================================================
# Optional: Security
# ============================================================
# Secret for validating Jenkins webhook signatures
WEBHOOK_SECRET=your-webhook-secret-here
